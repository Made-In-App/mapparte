        {
          "_customTemplate": true,
          "_afterNavbarItem": false,
          "_customHTML": "<iframe src=\"https://docs.google.com/forms/d/e/1FAIpQLSekZCjWARo6ROFLfFLYdEswDMmvZRWcSl5NQx9prvJ53Y13Iw/viewform?embedded=true\" width=\"100%\" height=\"1400\" frameborder=\"0\" marginheight=\"0\" marginwidth=\"0\">Caricamento in corso...</iframe>",
