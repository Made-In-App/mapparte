          "_customHTML": "<!-- Place this tag where you want the Awesome Table Widget to render -->\n<div data-type=\"AwesomeTableView\" data-viewid=\"-L7eVfW1g44j7XyqW7Gb\"></div>\n\n<!-- Place this tag in your head or just before your close body tag. -->\n{JS_CODE_0}",
          "_customCSS": ".google-maps {\n  position: relative;\n  padding-bottom: 75%; // Definisco l'aspect ratio\n  height: 0;\n  overflow: hidden;\n}\n.google-maps > iframe {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100% !important;\n  height: 100% !important;\n}",
